{
    "name": "ranitachi/filemanager-laravel",
    "description": "A secure, modular, and extensible File Manager for Laravel with RBAC, multi-storage, audit log, and WYSIWYG editor integration.",
    "keywords": ["laravel", "file-manager", "rbac", "s3", "minio", "ckeditor", "tinymce", "file-upload", "secure"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Fachran",
            "email": "fachran@users.noreply.github.com"
        }
    ],
   "require": {
    "php": "^8.0|^8.1|^8.2",
    "illuminate/contracts": "^9.0|^10.0|^11.0",
    "illuminate/support": "^9.0|^10.0|^11.0",
    "illuminate/database": "^9.0|^10.0|^11.0",
    "illuminate/http": "^9.0|^10.0|^11.0",
    "illuminate/routing": "^9.0|^10.0|^11.0",
    "illuminate/filesystem": "^9.0|^10.0|^11.0",
    "illuminate/cache": "^9.0|^10.0|^11.0",
    "illuminate/queue": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "Fachran\\FileManager\\": "src/"
        },
        "files": [
            "src/Support/namespace_aliases.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Fachran\\FileManager\\Tests\\": "tests/",
            "Fachran\\FileManager\\Database\\Factories\\": "database/factories/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ranitachi\\FileManager\\FileManagerServiceProvider"
            ],
            "aliases": {
                "FileManager": "Ranitachi\\FileManager\\Facades\\FileManager"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
